{
  "$schema": "https://langgra.ph/schema.json",
  "dependencies": ["."],
  "graphs": {
    "Anubis": "./src/anubis/graph.py:graph"
  },
  "store": {
    "index": {
      "dims": 384,
      "embed": "huggingface:sentence-transformers/all-MiniLM-L6-v2",
      "fields": ["document.kwargs.page_content"]
    }
  },
  "env": ".env",
  "image_distro": "wolfi",
  "http": {
    "app": "./src/api/webapp.py:app"
  }
}
