{
  "$schema": "https://langgra.ph/schema.json",
  "dependencies": ["."],
  "graphs": {
    "Anubis": "./src/anubis/graph.py:graph",
    "process_media_graph_api_endpoint": "./src/subgraphs/process_media_graph/process_media_graph_api_endpoint.py:process_media_graph_api_endpoint"
  },
  "store": {
    "index": {
      "dims": 384,
      "embed": "huggingface:sentence-transformers/all-MiniLM-L6-v2",
      "embedding_kwargs": {
        "cache_folder": "src/models/",
        "local_files_only": false
      }
    },
    "ttl": {
      "refresh_on_read": false
    },
    "type": "memory"
  },
  "http": {
    "app": "src/anubis/webapp.py:app"
  },
  "env": ".env.dev"
}
